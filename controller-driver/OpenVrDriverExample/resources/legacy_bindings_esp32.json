{
  "bindings": {
    "/actions/legacy": {
      "sources": [
        {
          "inputs": {
            "click": {
              "output": "/actions/legacy/in/right_axis1_press"
            },
            "pull": {
              "output": "/actions/legacy/in/right_axis1_value"
            }
          },
          "mode": "trigger",
          "path": "/user/esp32_controller2/input/trigger"
        }
      ]
    }
  },
  "controller_type": "my_custom_esp32_controller",
  "description": "Legacy bindings for ESP32 Controller to act as a right trigger.",
  "name": "ESP32 Legacy Bindings"
}